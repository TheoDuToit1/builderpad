# GEMINI_API_KEY: Required for Gemini AI API calls.
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# VITE_APP_URL: The URL where this app is hosted (used for share links).
# For local development: http://localhost:3000
# For production: Your Vercel deployment URL (e.g., https://your-app.vercel.app)
# Note: Vercel automatically provides VERCEL_URL, but you need to set VITE_APP_URL explicitly
VITE_APP_URL="http://localhost:3000"
